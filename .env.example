# Copy to .env.local and fill in as credentials become available.
# Every integration below degrades gracefully to the built-in mock data when
# its env vars are absent — the app runs fully without any of these set.

# --- InsForge (Postgres + auth + host) — verified SDK: @insforge/sdk ---
# Get these by running `npx @insforge/cli create` then `npx @insforge/cli link`
# (or, for self-hosted/OSS, `npx @insforge/cli link --api-base-url ... --api-key ...`).
# Values land in .insforge/project.json after linking.
INSFORGE_BASE_URL=
INSFORGE_API_KEY=

# --- Nimble (live-web data engine) — verified SDK: @nimble-way/nimble-js ---
NIMBLE_API_KEY=

# --- You.com (cited research) — verified SDK: @youdotcom-oss/sdk ---
YOU_API_KEY_AUTH=

# --- Band (agent interaction/governance layer) — verified SDK: @band-ai/rest-client ---
# Each of the 5 agents below must be registered by hand as an "External Agent"
# at app.band.ai/agents (sign up free, no CC — see band.ai/hacker-guide).
# The API key is shown once at registration time — copy it immediately.
BAND_PROSPECTOR_AGENT_ID=
BAND_PROSPECTOR_API_KEY=
BAND_RESEARCHER_AGENT_ID=
BAND_RESEARCHER_API_KEY=
BAND_WRITER_AGENT_ID=
BAND_WRITER_API_KEY=
BAND_COMPLIANCE_AGENT_ID=
BAND_COMPLIANCE_API_KEY=
BAND_MANAGER_AGENT_ID=
BAND_MANAGER_API_KEY=

# --- Hydra DB (policy/decision memory) — no public SDK found. ---
HYDRA_API_KEY=
HYDRA_BASE_URL=

# --- Kylon (workspace / "governed new hires" framing) — package found
# (kylon-cli) but undocumented. Confirm usage with the sponsor rep. ---
KYLON_API_KEY=
